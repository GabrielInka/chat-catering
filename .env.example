OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
# Documentación general (FAQ, condiciones, envíos, reglas): vector_docs salvo carpeta menus/
OPENAI_VECTOR_STORE_ID=vs_69dfb31cddb08191af92f4269135a085
# Solo menús (api/vector_docs/menus/). Opcional: si está vacío, solo se usa OPENAI_VECTOR_STORE_ID.
OPENAI_VECTOR_STORE_MENUS_ID=
AGENT_INSTRUCTIONS=
AGENT_INSTRUCTIONS_FILE=api/agent_instructions.md

WHATSAPP_TOKEN=EAA...
PHONE_NUMBER_ID=1148983021621569
VERIFY_TOKEN=baruchat_verify_token_2026

REQUEST_TIMEOUT_SECONDS=25

# Modo pruebas: solo responde a números en api/allowed_contacts.json
VERA_ALLOWLIST_ONLY=true

# Telegram (bandeja del operador). Desactivado por defecto.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Opcional: mismo valor que uses en setWebhook?secret_token=...
TELEGRAM_WEBHOOK_SECRET=
# Minutos sin respuesta automática de la IA tras responder tú por Telegram
HUMAN_PAUSE_MINUTES=30
